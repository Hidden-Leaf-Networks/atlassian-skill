# ============================================================================
# Atlassian Cloud Configuration
# ============================================================================
# Your Atlassian Cloud ID (found in admin settings or via API requests)
# To find: go to your-domain.atlassian.net, open dev tools, run:
#   window._siteConfig?.cloudId
# Or check the URL in any Atlassian REST API request
ATLASSIAN_CLOUD_ID=

# Your Atlassian site URL (no trailing slash)
ATLASSIAN_SITE_URL=https://your-domain.atlassian.net

# ============================================================================
# Authentication (Choose one method)
# ============================================================================

# --- Option 1: API Token (Recommended for development) ---
# Create at: https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_USER_EMAIL=
ATLASSIAN_API_TOKEN=

# --- Option 2: OAuth 2.0 (Recommended for production) ---
# Register an OAuth app at: https://developer.atlassian.com/console/myapps/
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
ATLASSIAN_REDIRECT_URI=http://localhost:3000/callback
ATLASSIAN_ACCESS_TOKEN=
ATLASSIAN_REFRESH_TOKEN=

# OAuth token metadata (managed automatically, rarely set manually)
# ATLASSIAN_TOKEN_EXPIRY=
# ATLASSIAN_TOKEN_SCOPE=

# ============================================================================
# Project Defaults
# ============================================================================
JIRA_PROJECT_KEY=
JIRA_BOARD_ID=
CONFLUENCE_SPACE_KEY=
BITBUCKET_WORKSPACE=
BITBUCKET_REPO_SLUG=

# ============================================================================
# Rate Limiting
# ============================================================================
# RATE_LIMIT_POINTS_PER_HOUR=65000
# RATE_LIMIT_REQUESTS_PER_SECOND=10

# ============================================================================
# Session Capture
# ============================================================================
SESSION_CAPTURE_ENABLED=true
SESSION_CAPTURE_MODE=full
SESSION_AUTO_ARCHIVE=false

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
